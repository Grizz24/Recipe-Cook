<Window x:Class="menu.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:menu"
        mc:Ignorable="d"
        Title="MainWindow"  Height="590" Width="800">
    
    <Grid ShowGridLines="False" Background="#22A699">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
            <Label Content="Recipe Name" Background="#F2BE22" FontFamily="Cascadia Mono SemiBold" FontSize="18" Margin="10" Width="130" HorizontalContentAlignment="Right" FontWeight="Bold"/>
            <TextBox x:Name="txtName" Margin="10" Width="230" />
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
            <Label Content="Quantity " Background="#F2BE22" FontFamily="Cascadia Mono SemiBold" FontSize="18" Margin="10" Width="130" HorizontalContentAlignment="Right" FontWeight="Bold"/>
            <TextBox x:Name="txtQuantity" Margin="10" Width="230" />
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Vertical">
            <Label Content="Ingredients" Background="#F2BE22" FontFamily="Cascadia Mono SemiBold" FontSize="18" Margin="10" Width="130" HorizontalContentAlignment="Right" FontWeight="Bold"/>
            <TextBox x:Name="txtIngredient" TextWrapping="Wrap" AcceptsReturn="True" Margin="10" Width="430" Height="100" />
        </StackPanel>

        <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Vertical">
            <Label Content="Steps" Background="#F2BE22" FontFamily="Cascadia Mono SemiBold" FontSize="18" Margin="10" Width="60" HorizontalContentAlignment="Right" FontWeight="Bold"/>
            <TextBox x:Name="txtSteps" TextWrapping="Wrap" AcceptsReturn="True" Margin="10,0,10,10" Width="430" Height="195" />
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal">
            <Label Content="Calories" Background="#F2BE22" FontFamily="Cascadia Mono SemiBold" FontSize="18" Margin="10" Width="90" HorizontalContentAlignment="Right" FontWeight="Bold"/>
            <TextBox x:Name="txtCalories" TextWrapping="Wrap" AcceptsReturn="True" Margin="10" Width="230" Height="30" />
        </StackPanel>

        <StackPanel Grid.Row="5" Grid.Column="0">
            <Button x:Name="btnSave" Content="Save" Background="#F24C3D" FontFamily ="Cascadia Mono SemiBold" FontSize="20" HorizontalAlignment="Center" Height="50" Width="280" Margin="10" FontWeight="Bold" Click="btnSave_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Grid.Column="1">
            <Button x:Name="btnDisplay" Content="Display" Background="#F24C3D" FontFamily ="Cascadia Mono SemiBold" FontSize="20" HorizontalAlignment="Center" Height="50" Width="280" Margin="10" FontWeight="Bold" Click="btnDisplay_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Grid.Column="2">
            <Button x:Name="btnAdjust" Content="Adjust" Background="#F24C3D" FontFamily ="Cascadia Mono SemiBold" FontSize="20" HorizontalAlignment="Center" Height="50" Width="280" Margin="10" FontWeight="Bold" Click="btnAdjust_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Vertical">
            <Label Content="Food Group" Background="#F2BE22" FontFamily="Cascadia Mono SemiBold" FontSize="18" Margin="10" Width="122" HorizontalContentAlignment="Right" FontWeight="Bold"/>
            <TextBox x:Name="txtGroup" TextWrapping="Wrap" AcceptsReturn="True" Margin="10" Width="430" Height="100" />
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Vertical">
            <Label Content="Recipe" Background="#F2BE22" FontFamily="Cascadia Mono SemiBold" FontSize="18" Margin="10" Width="75" HorizontalContentAlignment="Right" FontWeight="Bold"/>
            <ListBox x:Name="lstDisplay" Margin="10" Height="100" SelectionChanged="lstDisplay_SelectionChanged" IsSynchronizedWithCurrentItem="True" ScrollViewer.HorizontalScrollBarVisibility="Visible"/>

        </StackPanel>

        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Vertical">
            <Label Content="Display" Background="#F2BE22" FontFamily="Cascadia Mono SemiBold" FontSize="18" Margin="10" Width="85" HorizontalContentAlignment="Right" FontWeight="Bold"/>
            <ListBox x:Name="lstDisplayAll" Margin="10,0,10,10" Height="195"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Vertical">
            <Label Content="Display Steps" Background="#F2BE22" FontFamily="Cascadia Mono SemiBold" FontSize="18" Margin="10" Width="150" HorizontalContentAlignment="Right" FontWeight="Bold"/>
            <ListBox x:Name="lstDisplaySteps" Margin="10,0,10,10" Height="195"/>
        </StackPanel>
    </Grid>
</Window>
