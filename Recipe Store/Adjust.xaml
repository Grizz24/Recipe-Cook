<Window x:Class="menu.Adjust"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:menu"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="500"
      Title="Adjust Value"  Height="500" Width="500">

    <Grid Background="#22A699">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <Label Content="Adjust values by the following" FontFamily="Lucida Sans Unicode" Background="#F2BE22" FontWeight="Bold" Margin="10" Width="200"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
                <RadioButton x:Name ="radHalf" GroupName="AdjustGroup" Content="Adjust by 0.5 " Margin="10" FontSize="20" IsChecked="True"/>
                <RadioButton x:Name ="rad2" GroupName="AdjustGroup" Content="Adjust by 2 " Margin="10" FontSize="20"/>
                <RadioButton x:Name ="rad3" GroupName="AdjustGroup" Content="Adjust by 3 " Margin="10" FontSize="20"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnAjust" Content="Adjust" Background="#F24C3D" Width="120" Height="30" Margin="10" FontSize="20" Click="btnAjust_Click"/>
                <Button x:Name="btnShow" Content="Show" Background="#F24C3D" Width="120" Height="30" Margin="10" FontSize="20" Click="btnShow_Click"/>
                <Button x:Name="btnExit" Content="Exit" Background="#F24C3D" Width="120" Height="30" Margin="10" FontSize="20" Click="btnExit_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Label Content="Name to adjust" Width="130" Margin="10" Height="30" FontFamily="Lucida Sans Unicode" FontSize="15" Background="#F2BE22" FontWeight="Bold"/>
                <TextBox x:Name="txtSearch" Width="190" Height="30" Margin="10"/>
            </StackPanel>
        </StackPanel>

        <ListBox Grid.Row="1" x:Name="lstShow" Margin="10" Width="380" Height="200" Background="white" FontFamily="Bahnschrift SemiBold"/>

    </Grid>
</Window>
